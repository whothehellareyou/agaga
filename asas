local _silentConns = {}

local function _silentMuteSound(snd)
    if not snd or not snd.Parent then return end
    local v0 = snd.Volume
    snd.Volume = 0
    pcall(function() snd:Stop() end)

    local conn = snd:GetPropertyChangedSignal("Volume"):Connect(function()
        if BrzS.silentSteps and snd.Parent and snd.Volume > 0 then
            snd.Volume = 0
            pcall(function() snd:Stop() end)
        end
    end)
    table.insert(_silentConns, {conn = conn, snd = snd, orig = v0})
end

local function _silentIsFootstep(name)
    local n = name:lower()

    return n:find("footstep") or n:find("walk") or n:find("run") or n:find("step") or
           n:find("land") or n:find("sprint") or n:find("jog")
end

local function _silentApply(char)
    if not char then return end
    for _, desc in pairs(char:GetDescendants()) do
        if desc:IsA("Sound") and _silentIsFootstep(desc.Name) then
            _silentMuteSound(desc)
        end
    end

    char.DescendantAdded:Connect(function(desc)
        if not BrzS.silentSteps then return end
        if desc:IsA("Sound") and _silentIsFootstep(desc.Name) then
            task.defer(function() _silentMuteSound(desc) end)
        end
    end)
end

local function _silentRestore()
    for _, entry in ipairs(_silentConns) do
        pcall(function() entry.conn:Disconnect() end)
        pcall(function()
            if entry.snd and entry.snd.Parent then
                entry.snd.Volume = entry.orig or 0.5
            end
        end)
    end
    _silentConns = {}
end

BrzS._silentStepsDisable = _silentRestore

local _prevSilentState = false
RunService.Heartbeat:Connect(function()
    local cur = BrzS.silentSteps
    if cur == _prevSilentState then return end
    _prevSilentState = cur
    if cur then
        _silentConns = {}
        _silentApply(player.Character)
    else
        _silentRestore()
    end
end)

player.CharacterAdded:Connect(function(char)
    if BrzS.silentSteps then
        task.wait(0.5)
        _silentConns = {}
        _silentApply(char)
    end
end)

-- save original zoom distances before third person ever touches them
local _tpOrigMaxZoom = nil
local _tpOrigMinZoom = nil

local function applyThirdPerson(enabled)
    if enabled then
        -- save originals once
        if _tpOrigMaxZoom == nil then
            _tpOrigMaxZoom = pcall(function() return player.CameraMaxZoomDistance end) and player.CameraMaxZoomDistance or 0.5
            _tpOrigMinZoom = pcall(function() return player.CameraMinZoomDistance end) and player.CameraMinZoomDistance or 0.5
        end

        player.CameraMode = Enum.CameraMode.Classic
        pcall(function()
            player.CameraMaxZoomDistance = BrzS.thirdPersonDist
            player.CameraMinZoomDistance = 0.5
            player.DevComputerCameraMode = Enum.DevComputerCameraMovementMode.Classic
        end)
    else
        -- force zoom to 0 to lock first person, then set mode
        pcall(function()
            player.CameraMaxZoomDistance = 0.5
            player.CameraMinZoomDistance = 0.5
        end)
        player.CameraMode = Enum.CameraMode.LockFirstPerson
        pcall(function()
            player.DevComputerCameraMode = Enum.DevComputerCameraMovementMode.Default
        end)
        -- restore original zoom after a tick so the game accepts it
        task.delay(0.1, function()
            pcall(function()
                player.CameraMaxZoomDistance = _tpOrigMaxZoom or 0.5
                player.CameraMinZoomDistance = _tpOrigMinZoom or 0.5
            end)
            _tpOrigMaxZoom = nil
            _tpOrigMinZoom = nil
        end)
    end
end

local _tpTimer = 0
RunService.Heartbeat:Connect(function(dt)
    _tpTimer = _tpTimer + dt
    if _tpTimer < 0.2 then return end
    _tpTimer = 0
    if BrzS.thirdPerson then
        if player.CameraMode ~= Enum.CameraMode.Classic then
            player.CameraMode = Enum.CameraMode.Classic
        end
        pcall(function()
            if player.CameraMaxZoomDistance ~= BrzS.thirdPersonDist then
                player.CameraMaxZoomDistance = BrzS.thirdPersonDist
            end
        end)
    else
        -- keep enforcing first person until restored
        if player.CameraMode ~= Enum.CameraMode.LockFirstPerson then
            pcall(function() player.CameraMode = Enum.CameraMode.LockFirstPerson end)
        end
    end
end)

