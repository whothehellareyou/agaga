                deleteAt()

            elseif kc == Enum.KeyCode.Delete then

                if cur_pos < #inp_str then
                    local before = inp_str:sub(1, cur_pos)
                    local after  = inp_str:sub(cur_pos + 2)
                    inp_str = before .. after
                    updInp()
                end

            elseif kc == Enum.KeyCode.Left then
                if cur_pos > 0 then
                    cur_pos = ctrl and 0 or (cur_pos - 1)
                    updInp()
                end

            elseif kc == Enum.KeyCode.Right then
                if cur_pos < #inp_str then
                    cur_pos = ctrl and #inp_str or (cur_pos + 1)
                    updInp()
                end

            elseif kc == Enum.KeyCode.Home then
                cur_pos = 0; updInp()

            elseif kc == Enum.KeyCode.End then
                cur_pos = #inp_str; updInp()

            elseif ctrl and kc == Enum.KeyCode.V then
                doPaste()

            elseif ctrl and kc == Enum.KeyCode.A then

                cur_pos = #inp_str; updInp()

            else

                if ctrl then return end

                local n  = kc.Name
                local ch = nil

                if #n == 1 and n:match("[A-Z]") then
                    ch = sh and n or n:lower()
                elseif n:match("^%d$") then
                    ch = sh and ({"!","@","#","$","%","^","&","*","(",")"})[ tonumber(n) + 1 ] or n
                elseif n == "Space"     then ch = " "
                elseif n == "Minus"     then ch = sh and "_"  or "-"
                elseif n == "Equals"    then ch = sh and "+"  or "="
                elseif n == "Period"    then ch = sh and ">"  or "."
                elseif n == "Slash"     then ch = sh and "?"  or "/"
                elseif n == "Semicolon" then ch = sh and ":"  or ";"
                end

                if ch then insertAt(ch) end
            end
        end)
        c(UIS.InputChanged, function(inp)
            if done or not drag.on then return end
            if inp.UserInputType==Enum.UserInputType.MouseMovement then
                local m=UIS:GetMouseLocation()
                move(m.X-drag.lx, m.Y-drag.ly)
                drag.lx=m.X; drag.ly=m.Y
            end
        end)
        c(UIS.InputEnded, function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then drag.on=false end
        end)
        c(RS.Heartbeat, function(dt)
            if done then for _,co in ipairs(conns) do pcall(function() co:Disconnect() end) end; return end
            bt=bt+dt; if bt>=0.5 then bt=0; bon=not bon end
            cur.Visible=focused and bon
            bbg.Color=inR(px+W/2-65,py+106,130,24) and Color3.fromRGB(255,185,220) or C.acc
        end)
    end

    if tryAuto() then
        print("[EH] exchange.hook | auto-validated, skipping key UI")
        _KS_done = true
    else
        print("[EH] exchange.hook | waiting for key...")
        showUI()
        keyEvent.Event:Wait()
        _KS_done = true
    end
end

