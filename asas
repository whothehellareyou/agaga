drawESPEntry = function(d, char, color, myHRP)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")

    if not hrp or not head then
        hideESPEntry(d)
        return
    end

    local topWorld = head.Position + Vector3.new(0, 0.75, 0)
    local bottomWorld = hrp.Position - Vector3.new(0, 3.6, 0)
    local topScreen, topVisible, topZ = w2s(topWorld)
    local bottomScreen = w2s(bottomWorld)

    if (topZ and topZ < 0) or not topVisible then
        hideESPEntry(d)
        return
    end

    local distance = myHRP and (myHRP.Position - hrp.Position).Magnitude or 99999
    if distance > espS.renderDistance then
        hideESPEntry(d)
        return
    end

    local height = math.max(8, math.abs(topScreen.Y - bottomScreen.Y))
    local width = height * 0.55
    local left = topScreen.X - width / 2
    local right = topScreen.X + width / 2
    local top = topScreen.Y
    local bottom = bottomScreen.Y
    local centerX = topScreen.X
    local centerY = (top + bottom) / 2

    local charVisible = isVisible(hrp.Position, char)
    local drawColor = (espVisCheck and charVisible) and Color3.fromRGB(80, 255, 120) or color

    if espS.boxFill then
        d.boxFill.Position = Vector2.new(left, top)
        d.boxFill.Size = Vector2.new(width, height)
        d.boxFill.Color = drawColor
        d.boxFill.Transparency = espS.boxFillTransparency
        d.boxFill.Visible = true
    else
        d.boxFill.Visible = false
    end

    d.box2d.Visible = false
    for _, l in ipairs(d.corners) do l.Visible = false end
    for _, l in ipairs(d.lines3d) do l.Visible = false end

    if espS.boxMode == "2D" then
        d.box2d.Color = drawColor
        d.box2d.Position = Vector2.new(left, top)
        d.box2d.Size = Vector2.new(width, height)
        d.box2d.Visible = true

    elseif espS.boxMode == "Corner" then
        local cornerWidth = math.max(4, width * espS.boxCornerSize)
        local cornerHeight = math.max(4, height * espS.boxCornerSize)
        local corners = d.corners

        local points = {
            {left, top, left + cornerWidth, top},
            {left, top, left, top + cornerHeight},
            {right, top, right - cornerWidth, top},
            {right, top, right, top + cornerHeight},
            {left, bottom, left + cornerWidth, bottom},
            {left, bottom, left, bottom - cornerHeight},
            {right, bottom, right - cornerWidth, bottom},
            {right, bottom, right, bottom - cornerHeight}
        }

        for i, p in ipairs(points) do
            corners[i].From = Vector2.new(p[1], p[2])
            corners[i].To = Vector2.new(p[3], p[4])
            corners[i].Color = drawColor
            corners[i].Visible = true
        end

    elseif espS.boxMode == "3D" then
        local rightVec = hrp.CFrame.RightVector
        local lookVec = hrp.CFrame.LookVector
        local boxWidth = espS.box3DWidth
        local boxDepth = espS.box3DDepth

        local topY = topWorld.Y
        local bottomY = bottomWorld.Y
        local posX = hrp.Position.X
        local posZ = hrp.Position.Z

        local points = {
            Vector3.new(posX, topY, posZ) + rightVec * boxWidth + lookVec * boxDepth,
            Vector3.new(posX, topY, posZ) + rightVec * boxWidth - lookVec * boxDepth,
            Vector3.new(posX, topY, posZ) - rightVec * boxWidth - lookVec * boxDepth,
            Vector3.new(posX, topY, posZ) - rightVec * boxWidth + lookVec * boxDepth,
            Vector3.new(posX, bottomY, posZ) + rightVec * boxWidth + lookVec * boxDepth,
            Vector3.new(posX, bottomY, posZ) + rightVec * boxWidth - lookVec * boxDepth,
            Vector3.new(posX, bottomY, posZ) - rightVec * boxWidth - lookVec * boxDepth,
            Vector3.new(posX, bottomY, posZ) - rightVec * boxWidth + lookVec * boxDepth
        }

        local screenPoints = {}
        local valid = true

        for i, p in ipairs(points) do
            local s, v, z = w2s(p)
            screenPoints[i] = s
            if not v or (z and z < 0) then valid = false end
        end

        if valid then
            local edges = {
                {1,2}, {2,3}, {3,4}, {4,1},
                {5,6}, {6,7}, {7,8}, {8,5},
                {1,5}, {2,6}, {3,7}, {4,8}
            }

            for i, e in ipairs(edges) do
                d.lines3d[i].From = screenPoints[e[1]]
                d.lines3d[i].To = screenPoints[e[2]]
                d.lines3d[i].Color = drawColor
                d.lines3d[i].Visible = true
            end
        end
    end

    local humanoid = char:FindFirstChild("Humanoid")
    d.hpBg.Visible = false
    d.hpFg.Visible = false
    d.hpBgTop.Visible = false
    d.hpFgTop.Visible = false

    if espS.showHealth and humanoid then
        local hp    = humanoid.Health
        local hpMax = humanoid.MaxHealth
        -- some games use attributes for health — fall back if humanoid values look wrong
        if hpMax <= 0 or (hp <= 0 and humanoid.Health > 0) then
            local statFolder = ReplicatedStorage:FindFirstChild("Players") and ReplicatedStorage.Players:FindFirstChild(char.Name)
            local wsf = statFolder and statFolder:FindFirstChild("Status") and statFolder.Status:FindFirstChild("Journey") and statFolder.Status.Journey:FindFirstChild("WipeStatistics")
            if wsf then
                hp    = wsf:GetAttribute("Health") or hp
                hpMax = wsf:GetAttribute("MaxHealth") or hpMax
            end
        end
        -- wait for MaxHealth to be set by game on join
        if hpMax <= 0 then hpMax = 100 end
        local healthPercent = math.clamp(hp / hpMax, 0, 1)
        local healthColor = getHealthColor(healthPercent)
        local barWidth = espS.healthBarWidth

        if espS.healthPos == "Left" then
            local barX = left - barWidth - 3
            d.hpBg.Position = Vector2.new(barX, top)
            d.hpBg.Size = Vector2.new(barWidth, height)
            d.hpBg.Visible = true

            d.hpFg.Color = healthColor
            d.hpFg.Position = Vector2.new(barX, top + height * (1 - healthPercent))
            d.hpFg.Size = Vector2.new(barWidth, height * healthPercent)
            d.hpFg.Visible = healthPercent > 0

        elseif espS.healthPos == "Right" then
            local barX = right + 3
            d.hpBg.Position = Vector2.new(barX, top)
            d.hpBg.Size = Vector2.new(barWidth, height)
            d.hpBg.Visible = true

            d.hpFg.Color = healthColor
            d.hpFg.Position = Vector2.new(barX, top + height * (1 - healthPercent))
            d.hpFg.Size = Vector2.new(barWidth, height * healthPercent)
            d.hpFg.Visible = healthPercent > 0

        elseif espS.healthPos == "Top" then
            local barY = top - barWidth - 3
            d.hpBgTop.Position = Vector2.new(left, barY)
            d.hpBgTop.Size = Vector2.new(width, barWidth)
            d.hpBgTop.Visible = true

            d.hpFgTop.Color = healthColor
            d.hpFgTop.Position = Vector2.new(left, barY)
            d.hpFgTop.Size = Vector2.new(width * healthPercent, barWidth)
            d.hpFgTop.Visible = healthPercent > 0

        elseif espS.healthPos == "Bottom" then
            local barY = bottom + 3
            d.hpBgTop.Position = Vector2.new(left, barY)
            d.hpBgTop.Size = Vector2.new(width, barWidth)
            d.hpBgTop.Visible = true

            d.hpFgTop.Color = healthColor
            d.hpFgTop.Position = Vector2.new(left, barY)
            d.hpFgTop.Size = Vector2.new(width * healthPercent, barWidth)
            d.hpFgTop.Visible = healthPercent > 0
        end
    end


    if espS.showName then
        d.nameTxt.Text = char.Name
        d.nameTxt.Color = (espVisCheck and charVisible) and Color3.fromRGB(80, 255, 120) or (charVisible and espS.nameColor or Color3.fromRGB(160, 160, 160))
        d.nameTxt.Position = Vector2.new(centerX + espS.namePos.X, top + espS.namePos.Y)
        d.nameTxt.Visible = true
    else
        d.nameTxt.Visible = false
    end

    if espS.showDistance then
        d.distTxt.Text = string.format("[%dm]", math.floor(distance / 2.54 + 0.5))
        d.distTxt.Color = espS.distColor
        d.distTxt.Position = Vector2.new(centerX + espS.distPos.X, top + espS.distPos.Y)
        d.distTxt.Visible = true
    else
        d.distTxt.Visible = false
    end

    if espS.showWeapon then
        local weapon = findWeapon(char)
        if weapon then
            d.weapTxt.Text = weapon
            d.weapTxt.Color = espS.weapColor
            d.weapTxt.Position = Vector2.new(centerX + espS.weapPos.X, bottom + espS.weapPos.Y)
            d.weapTxt.Visible = true
        else
            d.weapTxt.Visible = false
        end
    else
        d.weapTxt.Visible = false
    end

    for i = 1, #d.skelLines do
        if d.skelLines[i] then
            d.skelLines[i].Visible = false
        end
    end

    if espS.showSkeleton then
        local boneIndex = 1
        for _, bonePair in ipairs(BONE_PAIRS) do
            local part1 = char:FindFirstChild(bonePair[1])
            local part2 = char:FindFirstChild(bonePair[2])

            if part1 and part2 then
                local screen1, vis1, z1 = w2s(part1.Position)
                local screen2, vis2, z2 = w2s(part2.Position)

                if vis1 and vis2 and (z1 or 0) > 0 and (z2 or 0) > 0 then
                    if not d.skelLines[boneIndex] then
                        d.skelLines[boneIndex] = newLine(espS.skeletonColor, espS.skeletonThickness)
                    end
                    d.skelLines[boneIndex].From = screen1
                    d.skelLines[boneIndex].To = screen2
                    d.skelLines[boneIndex].Color = espS.skeletonColor
                    d.skelLines[boneIndex].Thickness = espS.skeletonThickness
                    d.skelLines[boneIndex].Visible = true
                    boneIndex = boneIndex + 1
                end
            end
        end
    end

    if espS.showTracers then
        local viewport = cam.ViewportSize
        local origin

        if espS.tracerOrigin == "Bottom" then
            origin = Vector2.new(viewport.X / 2, viewport.Y)
        elseif espS.tracerOrigin == "Top" then
            origin = Vector2.new(viewport.X / 2, 0)
        elseif espS.tracerOrigin == "Center" then
            origin = Vector2.new(viewport.X / 2, viewport.Y / 2)
        else
            origin = UserInputService:GetMouseLocation()
        end

        d.tracer.From = origin
        d.tracer.To = Vector2.new(centerX, centerY)
        d.tracer.Color = espS.tracerColor
        d.tracer.Thickness = espS.tracerThickness
        d.tracer.Transparency = espS.tracerTransparency
        d.tracer.Visible = true
    else
        d.tracer.Visible = false
    end
end

