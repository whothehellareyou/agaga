Library._clickables = {}
Library._hoverables = {}

Library._dragSuppressed = false

UserInput.InputBegan:Connect(function(Input, _Useless)

    if not Library.WindowVisible then return end
    if Input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
    Library._dragSuppressed = false
    for _, item in ipairs(Library._clickables) do
        local blocked = false
        if item.dropdowns and item.side then
            for _, v in pairs(item.dropdowns[item.side]) do
                if v then blocked = true; break end
            end
        end
        if not blocked and Utility.OnMouse(item.hitbox) then
            Library._dragSuppressed = true
            item.callback(); return
        end
    end
end)

UserInput.InputEnded:Connect(function(Input)
    if Input.UserInputType == Enum.UserInputType.MouseButton1 then
        Library._dragSuppressed = false
    end
end)

UserInput.InputChanged:Connect(function(Input)
    if Input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
    if not Library.WindowVisible then return end
    if not next(Library._hoverables) then return end
    for _, item in ipairs(Library._hoverables) do
        if item.inline then
            pcall(function()
                item.inline.Color = Utility.OnMouse(item.hitbox) and Library.Theme.Accent[1] or Library.Theme.Inline
            end)
        end
    end
end)

