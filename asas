local function invGetPlayerFolder(name)
    local root = ReplicatedStorage:FindFirstChild("Players") or ReplicatedStorage:FindFirstChild("Player")
    return root and root:FindFirstChild(name)
end

local function invGetItemIcon(itemName)
    local list = ReplicatedStorage:FindFirstChild("ItemsList")
    if not list then return nil end
    local item = list:FindFirstChild(itemName)
    if item and item:FindFirstChild("ItemProperties") then
        local ic = item.ItemProperties:FindFirstChild("ItemIcon")
        if ic then return ic.Image end
    end
    return nil
end

local function invGetInventoryContents(playerName, folderNames)
    local folder = invGetPlayerFolder(playerName)
    if not folder then return {} end
    local invRoot   = folder:FindFirstChild("Inventory")
    local vaultRoot = folder:FindFirstChild("VaultStorage")
    local data = {}
    for _, bag in ipairs(folderNames) do
        local container
        if invRoot   then container = invRoot:FindFirstChild(bag) end
        if not container and vaultRoot then
            local vInv = vaultRoot:FindFirstChild("Inventory") or vaultRoot
            container = vInv:FindFirstChild(bag)
        end
        local src = (container and container:FindFirstChild("Inventory")) or container
        if src then
            for _, item in ipairs(src:GetChildren()) do
                local amt = item:GetAttribute("Amount") or item:GetAttribute("Quantity")
                if not amt and item:FindFirstChild("Amount") then amt = item.Amount.Value end
                if not amt and item:FindFirstChild("Quantity") then amt = item.Quantity.Value end
                table.insert(data, {Name = item.Name, Amount = formatAmount(amt or 1)})
            end
        end
    end
    return data
end

