local function getHWID()
    local parts = {}
    pcall(function()
        local vp = workspace.CurrentCamera.ViewportSize
        table.insert(parts, tostring(math.floor(vp.X)*10000+math.floor(vp.Y)))
    end)
    pcall(function()
        local cn = os.getenv("COMPUTERNAME") or os.getenv("HOSTNAME") or ""
        if cn ~= "" then table.insert(parts, cn) end
    end)
    if #parts == 0 then table.insert(parts, "FALLBACK") end
    local s = table.concat(parts, "|")
    local hash = 0
    for i = 1, #s do hash = (hash * 31 + s:byte(i)) % 2^32 end
    return string.format("HWID_%08X", hash)
end

local HWID = getHWID()

local function fetchKey(key)
    local ok, resp = pcall(function() return game:HttpGet(FIREBASE_URL .. "keys/" .. key .. ".json") end)
