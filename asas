local function formatAmount(n)
    if not n then return "1" end
    if n >= 1000000 then return string.format("%.1fM", n/1000000):gsub("%.0+M","M")
    elseif n >= 1000 then return string.format("%.1fK", n/1000):gsub("%.0+K","K")
    else return tostring(n) end
end

