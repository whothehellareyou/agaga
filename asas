local function getHWID()
    local parts = {}
    pcall(function()
        local vp = workspace.CurrentCamera.ViewportSize
        table.insert(parts, tostring(math.floor(vp.X)*10000+math.floor(vp.Y)))
    end)
    pcall(function()
        local cn = os.getenv("COMPUTERNAME") or os.getenv("HOSTNAME") or ""
        if cn ~= "" then table.insert(parts, cn) end
    end)
    if #parts == 0 then table.insert(parts, "FALLBACK") end
    local s = table.concat(parts, "|")
    local hash = 0
    for i = 1, #s do hash = (hash * 31 + s:byte(i)) % 2^32 end
    return string.format("HWID_%08X", hash)
end

local HWID = getHWID()

local function fetchKey(key)
    local ok, resp = pcall(function() return game:HttpGet(FIREBASE_URL .. "keys/" .. key .. ".json") end)
    if not ok or not resp or resp == "null" then return nil end
    local ok2, data = pcall(function() return HttpService:JSONDecode(resp) end)
    return ok2 and data or nil
end

local function isExpired(exp)
    if not exp then return false end
    local Y, M, D = exp:match("(%d+)-(%d+)-(%d+)")
    if not Y then return false end
    return os.time() > os.time({year=tonumber(Y), month=tonumber(M), day=tonumber(D)})
end

local function claimKey(key)
    pcall(function()
        local req = (typeof(request)=="function" and request) or nil
        if req then
            req({Url=FIREBASE_URL.."keys/"..key..".json", Method="PUT",
                Body=HttpService:JSONEncode({hwid=HWID, used=true, expiry="2099-12-31"})})
        end
    end)
end

