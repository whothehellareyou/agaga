    local ok2, data = pcall(function() return HttpService:JSONDecode(resp) end)
    return ok2 and data or nil
end

local function isExpired(exp)
    if not exp then return false end
    local Y, M, D = exp:match("(%d+)-(%d+)-(%d+)")
    if not Y then return false end
    return os.time() > os.time({year=tonumber(Y), month=tonumber(M), day=tonumber(D)})
end

local function claimKey(key)
