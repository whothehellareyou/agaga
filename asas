removeLeafMeshes = function()
    if BrzS._leavesRemoved then return end
    BrzS._leavesRemoved = true
    -- hide foliage via SpawnerZones/Foliage (petal approach - more complete)
    local fol = workspace:FindFirstChild("SpawnerZones") and workspace.SpawnerZones:FindFirstChild("Foliage")
    if fol then
        for _, v in ipairs(fol:GetDescendants()) do
            if v:IsA("BasePart") then
                for _, c in ipairs(v:GetChildren()) do
                    if c:IsA("SurfaceAppearance") then
                        pcall(function() v.Parent = nil end)
                        break
                    end
                end
            end
        end
    end
    -- fallback: name-based hide for any stragglers
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("MeshPart") or obj:IsA("Part") then
            local n = obj.Name:lower()
            if n:find("leaf") or n:find("leaves") or n:find("foliage") then
                pcall(function()
                    obj.Transparency = 1
                    obj.CanCollide   = false
                end)
            end
        end
    end
end

BrzS.applyNoLeaves = function(enabled)
    local terrain = workspace:FindFirstChildOfClass("Terrain")
    if enabled then

        if terrain then pcall(function() sethiddenproperty(terrain, "Decoration", false) end) end

        removeLeafMeshes()

        if BrzS._leavesConn then BrzS._leavesConn:Disconnect() end
        BrzS._leavesConn = player.CharacterAdded:Connect(function()
            task.wait(0.5)
            BrzS._leavesRemoved = false
            removeLeafMeshes()
        end)
    else
        if terrain then pcall(function() sethiddenproperty(terrain, "Decoration", true) end) end
        if BrzS._leavesConn then BrzS._leavesConn:Disconnect(); BrzS._leavesConn = nil end
        BrzS._leavesRemoved = false
    end
end

