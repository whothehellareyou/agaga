hookPlayerForHitMarker = function(plr)
    if plr == player then return end
    local function tryHook(char)
        if not char then return end
        local hum = char:WaitForChild("Humanoid", 10)
        if not hum then return end
        hum.HealthChanged:Connect(function(newHP)
            if not BrzS.hitMarker then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp and newHP < hum.MaxHealth then
                showHitMarker(hrp.Position)
            end
        end)
    end
    if plr.Character then task.spawn(tryHook, plr.Character) end
    plr.CharacterAdded:Connect(function(char) task.spawn(tryHook, char) end)
end

