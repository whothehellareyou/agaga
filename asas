    Utility.AddDrag = function(Sensor, List)
        local DragUtility = {
            MousePos = Vector2.new(), PrevPos = Vector2.new(),
            Dragging = false, PendingDX = 0, PendingDY = 0
        }

        Utility.AddConnection(UserInput.InputBegan, function(Input, _Useless)

            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                if Utility.OnMouse(Sensor) then

                    local onClickable = false
                    if Library._clickables then
                        for _, item in ipairs(Library._clickables) do
                            if item.hitbox and Utility.OnMouse(item.hitbox) then
                                onClickable = true; break
                            end
                        end
                    end
                    if not onClickable and not Library._dragSuppressed then
                        DragUtility.Dragging = true
                        DragUtility.PrevPos = UserInput:GetMouseLocation()
                        DragUtility.PendingDX = 0
                        DragUtility.PendingDY = 0
                    end
                end
            end
        end)

        Utility.AddConnection(UserInput.InputEnded, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                DragUtility.Dragging = false
            end
        end)

        Utility.AddConnection(UserInput.InputChanged, function(Input)
            if Input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
            local cur = UserInput:GetMouseLocation()
            if DragUtility.Dragging then
                DragUtility.PendingDX = DragUtility.PendingDX + (cur.X - DragUtility.PrevPos.X)
                DragUtility.PendingDY = DragUtility.PendingDY + (cur.Y - DragUtility.PrevPos.Y)
            end
            DragUtility.PrevPos = cur
        end)

        local _dragCache = nil
        Utility.AddConnection(RunService.RenderStepped, function()
            if not DragUtility.Dragging then
                _dragCache = nil
                return
            end
            local dx, dy = DragUtility.PendingDX, DragUtility.PendingDY
            if dx == 0 and dy == 0 then return end
            DragUtility.PendingDX = 0
            DragUtility.PendingDY = 0

            if not _dragCache then
                _dragCache = {}
                for _, Value in pairs(List) do
                    if Value ~= nil and Value[1] ~= nil then
                        _dragCache[#_dragCache + 1] = Value[1]
                    end
                end
            end
            local n = #_dragCache
            for i = 1, n do
                local d = _dragCache[i]
                local p = d.Position
                d.Position = Vector2.new(p.X + dx, p.Y + dy)
            end
        end)
    end

