removeESPEntry = function(d)
    if not d then return end
    local objects = {"box2d", "boxFill", "hpBg", "hpFg", "hpBgTop", "hpFgTop", "nameTxt", "distTxt", "weapTxt", "tracer"}
    for _, k in ipairs(objects) do
        pcall(function() if d[k] then d[k]:Remove() end end)
    end
    for _, l in ipairs(d.corners) do pcall(function() l:Remove() end) end
    for _, l in ipairs(d.lines3d) do pcall(function() l:Remove() end) end
    for _, l in ipairs(d.skelLines) do pcall(function() l:Remove() end) end
    if d.highlight then pcall(function() d.highlight:Destroy() end) end
end

