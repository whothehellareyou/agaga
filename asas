local function getCurrentWeaponName()
    local char = player.Character
    if not char then return nil end
    for _, obj in ipairs(char:GetChildren()) do
        if obj:IsA("Tool") then return obj.Name end
    end

    local vm = cam:FindFirstChild("ViewModel")
    if vm then
        local item = vm:FindFirstChild("Item")
        if item then return item.Name end
    end
    return nil
end

local function getSkinsForWeapon(weaponName)
    local skins = ReplicatedStorage:FindFirstChild("Skins")
    if not skins then return SKIN_NAMES end
    local found = {}
    table.insert(found, "Default")
    for _, folder in ipairs(skins:GetChildren()) do

        if weaponName then

            local weaponFolder = folder:FindFirstChild(weaponName)
            if weaponFolder then
                table.insert(found, folder.Name)
            end
        else
            table.insert(found, folder.Name)
        end
    end
    if #found <= 1 then return SKIN_NAMES end
    return found
end

