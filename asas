local function applySkin(skinName)
    if skinName == "Default" then return end
    local skins = ReplicatedStorage:FindFirstChild("Skins")
    if not skins then

        skins = ReplicatedStorage:FindFirstChild("WeaponSkins") or ReplicatedStorage:FindFirstChild("ItemSkins")
    end
    if not skins then return end

    local vm = getViewModel()
    if not vm then return end

    local item = vm:FindFirstChild("Item")
    if not item then

        for _, child in ipairs(vm:GetChildren()) do
            if child:IsA("Model") or child:IsA("Tool") then
                item = child
                break
            end
        end
    end
    if not item then return end

    local itemName = item.Name

    if itemName == "Item" or itemName == "" then
        local nameAttr = item:GetAttribute("WeaponId") or item:GetAttribute("ItemName") or item:GetAttribute("Name")
        if nameAttr then itemName = nameAttr end
    end

    local skinFolder = nil
    for _, folder in ipairs(skins:GetChildren()) do
        if folder.Name == skinName then
            skinFolder = folder
            break
        end
    end
    if not skinFolder then return end

    for _, part in ipairs(item:GetDescendants()) do
        local sa = part:FindFirstChildOfClass("SurfaceAppearance")
        if sa then sa:Destroy() end
    end

    local texNode = skinFolder:FindFirstChild(itemName)
    if texNode then texNode = texNode:FindFirstChild("Textures") or texNode end
    if not texNode then
        texNode = skinFolder:FindFirstChild("Textures")
            or skinFolder:FindFirstChild("Base")
            or skinFolder
    end

    local baseTexId = nil
    if texNode then
        local baseChild = texNode:FindFirstChild("Base")
            or texNode:FindFirstChild("Diffuse")
            or texNode:FindFirstChild("Color")
        if baseChild then
            baseTexId = baseChild.Value or nil
        elseif texNode:IsA("StringValue") then
            baseTexId = texNode.Value
        end
    end

    local appliedCount = 0
    for _, part in ipairs(item:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("MeshPart") or part:IsA("SpecialMesh") then
            if part.Name ~= "AimPart" then
                if baseTexId and baseTexId ~= "" then
                    local newSA = Instance.new("SurfaceAppearance")
                    newSA.ColorMap = baseTexId
                    newSA.Parent = part
                    appliedCount = appliedCount + 1
                end
            end
        end
    end

    if appliedCount == 0 then

        local skinColor = skinFolder:GetAttribute("Color")
        if skinColor then
            for _, part in ipairs(item:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "AimPart" then
                    pcall(function() part.Color = skinColor end)
                end
            end
        end
    end
end

