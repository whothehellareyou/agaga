local function _saInFov(worldPos)
    local sp, onscreen = cam:WorldToViewportPoint(worldPos)
    if not onscreen then return false, math.huge end
    local centre = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
    local d      = (centre - Vector2.new(sp.X, sp.Y)).Magnitude
    local radius = _SA.dynamicFov and (_SA.actualFov * 90 / (cam.FieldOfView or 90)) or _SA.fovSize
    return d < radius, d
end

local function _saIsVisible(target)
    local myHead = player.Character and player.Character:FindFirstChild("Head")
    if not myHead then return false end
    local origin = myHead.Position + Vector3.new(0, 1, 0)
    local targetPos
    pcall(function()
        if target:IsA("Model") then
            local p = target:FindFirstChild(_SA.realAimPart)
            targetPos = p and p.Position
        elseif target.Character then
            local hrp = target.Character:FindFirstChild("HumanoidRootPart")
            targetPos = hrp and hrp.Position
        end
    end)
    if not targetPos then return false end
    local dir    = targetPos - origin
    local result = workspace:Raycast(origin, dir.Unit * dir.Magnitude)
    if result and result.Instance then
        return result.Instance.Parent:FindFirstChildOfClass("Humanoid") ~= nil
    end
    return false
end

local function _saIsValid(target)
    local isModel = target:IsA("Model")
    if not isModel then
        if not target.Character then return false end
        local hum = target.Character:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return false end
        if not target.Character:FindFirstChild("Head") then return false end
    else
        local hum = target:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return false end
    end

    if _SA.teamCheck and not isModel then
        local skip = false
        pcall(function()
            local rsP = ReplicatedStorage:FindFirstChild("Players")
            if not rsP then return end
            local function getClan(p)
                return rsP[p.Name].Status.Journey.Clan:GetAttribute("CurrentClan")
            end
            local mc, tc = getClan(player), getClan(target)
            if mc and tc and mc == tc then skip = true end
        end)
        if skip then return false end
    end

    if BrzS.modWarnings and BrzS.modWarnings[target.Name] then return false end
    if _SA.visibleOnly and not _saIsVisible(target) then return false end
    return true
end

