    if espS.healthGradient == "GreenRed" then
        if pct > 0.6 then return Color3.fromRGB(120, 255, 160)
        elseif pct > 0.3 then return Color3.fromRGB(255, 200, 80)
        else return Color3.fromRGB(255, 85, 135) end
    elseif espS.healthGradient == "RedGreen" then
        if pct < 0.4 then return Color3.fromRGB(120, 255, 160)
        elseif pct < 0.7 then return Color3.fromRGB(255, 200, 80)
        else return Color3.fromRGB(255, 85, 135) end
    elseif espS.healthGradient == "StaticGreen" then
        return Color3.fromRGB(120, 255, 160)
    elseif espS.healthGradient == "StaticRed" then
        return Color3.fromRGB(255, 85, 135)
    else
        return espS.healthColor
    end
end

