local function _saRunAimbot()
    if not _SA.enabled or not _SA.silentAimbot or not _SA.lastTarget then
        if _saTracer then _saTracer.Visible = false end
        return
    end
    local tp = _saGetTargetPart()
    if not tp then if _saTracer then _saTracer.Visible = false end; return end

    if _SA.aimbotTracer and _saTracer then
        local sp, on = cam:WorldToViewportPoint(tp.Position)
        _saTracer.Visible = on
        if on then
            _saTracer.Color = _SA.tracerColor
            _saTracer.Transparency = 1
            _saTracer.From = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
            _saTracer.To   = Vector2.new(sp.X, sp.Y)
        end
    elseif _saTracer then
        _saTracer.Visible = false
    end

    if _SA.silentChance < math.random() * 100 then return end

    local vm = cam:FindFirstChild("ViewModel")
    if not vm then return end

    local predictedPos = tp.Position
    if _SA.prediction then
        local mv = _saGetAmmoAttr("MuzzleVelocity")
        if mv and mv > 100 then
            local dist = (tp.Position - cam.CFrame.Position).Magnitude
            local t    = dist / mv * 1.33
            local hrp
            pcall(function()
                if _SA.lastTarget:IsA("Model") then
                    hrp = _SA.lastTarget:FindFirstChild("HumanoidRootPart")
                elseif _SA.lastTarget.Character then
                    hrp = _SA.lastTarget.Character:FindFirstChild("HumanoidRootPart")
                end
            end)
            if hrp then
                local vel = hrp.AssemblyLinearVelocity
                local off = _SA.perfectSilent and 0.15 or 1.75
                predictedPos = Vector3.new(
                    tp.Position.X + vel.X * t,
                    tp.Position.Y - off,
                    tp.Position.Z + vel.Z * t
                )
            end
        end
    else
        local off = _SA.perfectSilent and 0.15 or 1.75
        predictedPos = tp.Position - Vector3.new(0, off, 0)
    end

    local vmPart
    if _SA.perfectSilent then
        local item = vm:FindFirstChild("Item")
        local aps  = item and item:FindFirstChild("AttachmentPoints")
        vmPart = aps and aps:FindFirstChild("Extra")
    end
    vmPart = vmPart or vm:FindFirstChild("HumanoidRootPart")
    if vmPart and predictedPos then
        vmPart.CFrame = CFrame.new(vmPart.Position, predictedPos)
    end
end

local _ehNCOld = nil
pcall(function()
    local _mt = getrawmetatable(game)
    setreadonly(_mt, false)
    _ehNCOld = _mt.__namecall
    _mt.__namecall = newcclosure(function(self, ...)
        if checkcaller() then return _ehNCOld(self, ...) end
        local method = getnamecallmethod()
        local args = {...}

        if BrzS.instantHit and method == "FireServer" and self.Name == "ProjectileInflict" then
            if type(args[3]) == "number" and args[3] >= -20 and args[3] <= 20 then
                return coroutine.yield()
            end
            args[4] = 0/0
            return _ehNCOld(self, table.unpack(args))
        end

        if BrzS.instantHit and method == "Raycast" then
            local tp = _saGetTargetPart()
            if tp and args[1] then
                pcall(function()
                    local info = getinfo(3)
                    if info and info.short_src and info.short_src:find("Bullet") then
                        args[2] = (tp.Position - args[1]).Unit * 9e16
                    end
                end)
                return _ehNCOld(self, table.unpack(args))
            end
        end

        if BrzS.forceHit and method == "FireServer" and self.Name == "ProjectileInflict" then
            local tp = _saGetTargetPart()
            if tp then
                args[2] = tp
                args[3] = (tp.Position - workspace.CurrentCamera.CFrame.Position).Magnitude
                args[4] = 0/0
                return _ehNCOld(self, table.unpack(args))
            end
        end

        return _ehNCOld(self, ...)
    end)
    setreadonly(_mt, true)
end)

local function _saAutoShootTick()
    if not _SA.autoShoot or not _SA.enabled or not _SA.lastTarget then return end
    if not _saEnsureRemotes() then return end
    local tp = _saGetTargetPart()
    if not tp then return end
    local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP or (tp.Position - myHRP.Position).Magnitude > 2000 then return end
    if not _saIsVisible(_SA.lastTarget) then return end

    local vm = cam:FindFirstChild("ViewModel")
    if not (vm and vm:FindFirstChild("Item") and vm.Item:FindFirstChild("Offsets")) then return end
    local ap = vm.Item.Offsets:FindFirstChild("AimPart")
    if not ap then return end

    ap.CFrame = CFrame.lookAt(ap.Position, tp.Position)

    local now = tick()
    if now - _SA.lastFireTime < _SA.instantHitDelay then return end
    _SA.lastFireTime = now
    local seed = math.random(-10000, 10000)
    local success = _saRemFP:InvokeServer(Vector3.new(0/0, 0/0, 0/0), seed, now)
    if success then
        task.spawn(function()
            _saRemPI:FireServer(
                tp,
                tp.CFrame:ToObjectSpace(CFrame.new(tp.Position + Vector3.new(0, 1, 0) * 0.01)),
                seed,
                0/0
            )
        end)
    end
end

local function _saResolverTick()
    if not _SA.resolver then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            pcall(function()
                local hrp  = plr.Character:FindFirstChild("HumanoidRootPart")
                local rsP  = ReplicatedStorage.Players:FindFirstChild(plr.Name)
                local lastVP = rsP and rsP.Status.UAC:GetAttribute("LastVerifiedPos")
                if not (hrp and lastVP) then return end
                local delta = (hrp.Position - lastVP).Magnitude
                if not _SA.resolverCache[plr.Name] then _SA.resolverCache[plr.Name] = 0 end
                if delta >= 10 then
                    _SA.resolverCache[plr.Name] += 1
                    if _SA.resolverCache[plr.Name] >= 250 then
                        _SA.resolverCache[plr.Name] = 0
                        BrzS.cheatWarnings[plr.Name] = true
                        game:GetService("StarterGui"):SetCore("SendNotification", {
                            Title = "Cheat | Resolver: " .. plr.Name,
                            Text  = "Missclick/rathack suspected (delta " .. math.floor(delta) .. " st)",
                            Duration = 8
                        })
                    end
                end
            end)
        end
    end
end

local function _saHandleFreeze()
    if _SA.freezeTarget and _SA.lastTarget then
        local nm = _SA.lastTarget.Name
        if not _SA.freezeList[nm] then _SA.freezeList[nm] = _SA.lastTarget end
        pcall(function()
            local char = _SA.lastTarget:IsA("Model") and _SA.lastTarget or _SA.lastTarget.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.Anchored = true end
        end)
    elseif not _SA.freezeTarget and next(_SA.freezeList) then
        for _, tgt in pairs(_SA.freezeList) do
            pcall(function()
                local char = tgt:IsA("Model") and tgt or tgt.Character
                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then hrp.Anchored = false end
            end)
        end
        _SA.freezeList = {}
    end
end

