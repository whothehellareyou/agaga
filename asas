_modWarnCount = {}; _modChecked = {}

local function _modNotify(name, accountAge, reason)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title    = "Mod Detector: " .. name,
        Text     = reason .. " | Age:" .. accountAge .. "d",
        Duration = 8
    })
    print("[EH ModDetect] " .. name .. " | " .. reason)
end

runModDetector = function()
    if not BrzS.modDetector then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == player then continue end
        if not _modWarnCount[plr.Name] then _modWarnCount[plr.Name] = 0 end
        if _modWarnCount[plr.Name] >= 5 then continue end

        pcall(function()
            local rsp    = ReplicatedStorage:FindFirstChild("Players")
            local rspPlr = rsp and rsp:FindFirstChild(plr.Name)
            local status = rspPlr and rspPlr:FindFirstChild("Status")
            local gv     = status and status:FindFirstChild("GameplayVariables")
            if gv and (gv:GetAttribute("PremiumLevel") or 0) >= 4 then
                if not BrzS.modWarnings[plr.Name] then
                    BrzS.modWarnings[plr.Name] = true
                    _modWarnCount[plr.Name] += 1
                    _modNotify(plr.Name, plr.AccountAge, "Mod (A) - PremiumLevel >=4")
                end
            end
        end)

        if plr.Character and not _modChecked[plr.Name] then
            local invisCount, totalCount = 0, 0
            local BODY = {
                "Head","UpperTorso","LowerTorso",
                "LeftUpperArm","LeftLowerArm","LeftHand",
                "RightUpperArm","RightLowerArm","RightHand",
                "LeftUpperLeg","LeftLowerLeg","LeftFoot",
                "RightUpperLeg","RightLowerLeg","RightFoot"
            }
            for _, n in ipairs(BODY) do
                local p = plr.Character:FindFirstChild(n)
                if p and p:IsA("BasePart") then
                    totalCount += 1
                    if p.Transparency >= 0.9 then invisCount += 1 end
                end
            end
            if totalCount > 0 and invisCount == totalCount then
                if not BrzS.modWarnings[plr.Name] then
                    BrzS.modWarnings[plr.Name] = true
                    _modWarnCount[plr.Name] += 1
                    _modNotify(plr.Name, plr.AccountAge, "Mod (B) - Invisible (" .. invisCount .. "/" .. totalCount .. " parts)")
                end
            end
            _modChecked[plr.Name] = true
        end

        pcall(function()
            local rsp    = ReplicatedStorage:FindFirstChild("Players")
            local rspPlr = rsp and rsp:FindFirstChild(plr.Name)
            local status = rspPlr and rspPlr:FindFirstChild("Status")
            if not status then return end
            local uac  = status:FindFirstChild("UAC")
            local vars = status:FindFirstChild("GameplayVariables")
            if uac then
                for _, flagName in ipairs({"A1Detected","A2Detected","A3Detected"}) do
                    if uac:GetAttribute(flagName) == true then
                        if not BrzS.modWarnings[plr.Name] then
                            BrzS.modWarnings[plr.Name] = true
                            _modWarnCount[plr.Name] += 1
                            _modNotify(plr.Name, plr.AccountAge, "Mod (C) - UAC " .. flagName)
                        end
                        break
                    end
                end
                if uac:GetAttribute("Enabled") == true then
                    if not BrzS.modWarnings[plr.Name] then
                        BrzS.modWarnings[plr.Name] = true
                        _modWarnCount[plr.Name] += 1
                        _modNotify(plr.Name, plr.AccountAge, "Mod (C) - UAC Enabled")
                    end
                end
            end
            if vars and vars:GetAttribute("Godmode") == true then
                if not BrzS.modWarnings[plr.Name] then
                    BrzS.modWarnings[plr.Name] = true
                    _modWarnCount[plr.Name] += 1
                    _modNotify(plr.Name, plr.AccountAge, "Mod (C) - Godmode active")
                end
            end
        end)
    end
end

runCheatDetector = function(plr)
    if not BrzS.cheatDetector then return end
    if plr == player then return end
    if BrzS.cheatWarnings[plr.Name] then return end
    pcall(function()
        local rsp      = ReplicatedStorage:FindFirstChild("Players")
        local rspPlr   = rsp and rsp:FindFirstChild(plr.Name)
        local status   = rspPlr and rspPlr:FindFirstChild("Status")
        local journey  = status and status:FindFirstChild("Journey")
        local wipeStats = journey and journey:FindFirstChild("WipeStatistics")
        if not wipeStats then return end

        local kills  = wipeStats:GetAttribute("Kills")  or 0
        local deaths = math.max(wipeStats:GetAttribute("Deaths") or 1, 1)
        local kdr    = kills / deaths

        local reportList = ReplicatedStorage:FindFirstChild("ReportList")
        local entry = reportList and (
            (reportList:FindFirstChild("MostWanted") and reportList.MostWanted:FindFirstChild(plr.Name)) or
            (reportList:FindFirstChild("Recent")     and reportList.Recent:FindFirstChild(plr.Name))
        )
        local totalFlags = entry and (entry:GetAttribute("TotalFlags") or 0) or 0
        local hsr        = entry and (entry:GetAttribute("HSR")        or 0) or 0
        local acctAge    = entry and (entry:GetAttribute("Age")        or 999) or 999

        local suspected, reasons = false, {}

        if kills >= 15 and kdr >= 5 then
            suspected = true
            table.insert(reasons, "KDR " .. string.format("%.1f", kdr) .. " (A)")
        end

        if kills >= 15 and hsr >= 95 then
            suspected = true
            table.insert(reasons, "HSR " .. hsr .. "% (B)")
        end

        if totalFlags >= 75 and acctAge <= 50 then
            suspected = true
            table.insert(reasons, "Flags " .. totalFlags .. "/age " .. acctAge .. "d (C)")
        end

        if not suspected then return end

        BrzS.cheatWarnings[plr.Name] = true
        local hrs     = math.floor((wipeStats:GetAttribute("TimePlayed") or 0) / 3600)
        local kdrStr  = string.format("%.1f", kdr)
        local detail  = "K:" .. kills .. " KDR:" .. kdrStr .. " HSR:" .. hsr .. "% Flags:" .. totalFlags
        if hrs > 0 then detail = detail .. " " .. hrs .. "h" end
        local reasonStr = table.concat(reasons, " | ")
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title    = "Cheat Suspect: " .. plr.Name,
            Text     = detail .. " - " .. reasonStr,
            Duration = 10
        })
        print("[EH CheatDetect] " .. plr.Name .. " | " .. detail .. " | " .. reasonStr)
    end)
end

