local function _saGetAmmoAttr(attr)
    local v = 0
    pcall(function()
        local rsP = ReplicatedStorage.Players:FindFirstChild(player.Name)
        if not rsP then return end
        local eqVal = rsP.Status.GameplayVariables.EquippedTool.Value
        if not eqVal then return end
        local item = rsP.Inventory:FindFirstChild(tostring(eqVal))
        if not item or not item:FindFirstChild("Attachments") then return end
        for _, att in ipairs(item.Attachments:GetChildren()) do
            local n = att.Name:lower()
            if n:find("mag") or n:find("rnd") then
                local loaded = att:FindFirstChild("LoadedAmmo")
                if loaded then
                    local first = loaded:GetChildren()[1]
                    if first then
                        local at = first:GetAttribute("AmmoType")
                        local af = at and ReplicatedStorage.AmmoTypes:FindFirstChild(at)
                        if af then v = af:GetAttribute(attr) or 0 end
                    end
                    return
                end
            end
        end
    end)
    return v
end

local function _saFindTarget()

    if _SA.stickyAim and _SA.lastTarget then
        local stillValid = false
        pcall(function()
            if not _saIsValid(_SA.lastTarget) then return end
            local p
            if _SA.lastTarget:IsA("Model") then
                p = _SA.lastTarget:FindFirstChild(_SA.realAimPart)
            elseif _SA.lastTarget.Character then
                p = _SA.lastTarget.Character:FindFirstChild(_SA.realAimPart)
            end
            if p then stillValid = _saInFov(p.Position) end
        end)
        if stillValid then return end
    end

    local best, bestD = nil, math.huge

    if _SA.targetPlayers then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player and _saIsValid(plr) then
                local ch = plr.Character
                local ap = ch and ch:FindFirstChild(_SA.realAimPart)
                if ap then
                    local inF, d = _saInFov(ap.Position)
                    if inF and d < bestD then bestD = d; best = plr end
                end
            end
        end
    end

    if _SA.targetAI then
        local az = workspace:FindFirstChild("AiZones")
        if az then
            for _, zone in ipairs(az:GetChildren()) do
                for _, npc in ipairs(zone:GetChildren()) do
                    if npc:IsA("Model") and npc:FindFirstChildOfClass("Humanoid") and _saIsValid(npc) then
                        local ap
                        if npc.Name == "MI24V" then

                            local pil = npc:FindFirstChild("Pilots")
                            ap = pil and (
                                (pil:FindFirstChild("Pilot")  and pil.Pilot:FindFirstChild("Head"))  or
                                (pil:FindFirstChild("Gunner") and pil.Gunner:FindFirstChild("Head"))
                            )
                        else
                            ap = npc:FindFirstChild(_SA.realAimPart)
                        end
                        if ap then
                            local inF, d = _saInFov(ap.Position)
                            if inF and d < bestD then
                                bestD = d

                                if npc.Name == "MI24V" then
                                    local pil = npc.Pilots
                                    best = pil:FindFirstChild("Pilot") or pil:FindFirstChild("Gunner") or npc
                                else
                                    best = npc
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    local now = tick()
    if best and (best ~= _SA.lastTarget or now - _SA.lastTargetTime >= 0.05) then
        _SA.lastTarget     = best
        _SA.lastTargetTime = now
    elseif not best then
        _SA.lastTarget = nil
    end
end

local function _saGetTargetPart()
    if not _SA.lastTarget then return nil end

    if _SA.nearestPart and not _SA.randomizePart then
        local char = _SA.lastTarget:IsA("Model") and _SA.lastTarget
                     or (_SA.lastTarget.Character)
        if char then
            local best, bestD = nil, math.huge
            for _, p in ipairs(char:GetChildren()) do
                if p:IsA("MeshPart") then
                    local sp, on = cam:WorldToViewportPoint(p.Position)
                    if on then
                        local c = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
                        local d = (c - Vector2.new(sp.X, sp.Y)).Magnitude
                        if d < bestD then bestD = d; best = p end
                    end
                end
            end
            if best then return best end
        end
    end

    local part
    pcall(function()
        if _SA.lastTarget:IsA("Model") then
            part = _SA.lastTarget:FindFirstChild(_SA.realAimPart)
                or _SA.lastTarget:FindFirstChild("Head")
        elseif _SA.lastTarget.Character then
            part = _SA.lastTarget.Character:FindFirstChild(_SA.realAimPart)
                or _SA.lastTarget.Character:FindFirstChild("Head")
        end
    end)
    return part
end

